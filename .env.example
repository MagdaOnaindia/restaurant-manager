# ── Base de datos (docker-compose levanta PostgreSQL con estos valores) ──
DATABASE_URL="postgresql://rms:rms@localhost:5433/rms_dev"

# ── API ──
API_PORT=4000
# URLs públicas de los frontends (CORS + enlaces en emails + QRs)
WEB_URL="http://localhost:3000"
PAY_URL="http://localhost:3001"

# ── JWT (generar valores aleatorios largos en producción) ──
JWT_ACCESS_SECRET="dev-access-secret-change-me"
JWT_REFRESH_SECRET="dev-refresh-secret-change-me"

# ── Email (Mailpit en desarrollo: docker-compose lo levanta en localhost:1025, UI en :8025) ──
SMTP_HOST="localhost"
SMTP_PORT=1025
SMTP_USER=""
SMTP_PASS=""
MAIL_FROM="Restaurant Manager <no-reply@rms.local>"

# ── Stripe (modo test; se rellenan en la Fase 8) ──
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PUBLISHABLE_KEY=""
