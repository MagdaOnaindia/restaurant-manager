# ── Database (docker-compose starts PostgreSQL with these values) ──
DATABASE_URL="postgresql://rms:rms@localhost:5433/rms_dev"

# ── API ──
API_PORT=4000
# Public API URL (used to build the URLs of uploaded photos)
API_PUBLIC_URL="http://localhost:4000"
# Public front-end URLs (CORS + links in emails + QRs)
WEB_URL="http://localhost:3100"
PAY_URL="http://localhost:3001"

# ── JWT (generate long random values in production) ──
JWT_ACCESS_SECRET="dev-access-secret-change-me"
JWT_REFRESH_SECRET="dev-refresh-secret-change-me"

# ── Email (Mailpit in development: docker-compose runs it on localhost:1025, UI on :8025) ──
SMTP_HOST="localhost"
SMTP_PORT=1025
SMTP_USER=""
SMTP_PASS=""
MAIL_FROM="Restaurant Manager <no-reply@rms.local>"

# ── Stripe (test mode; filled in during Phase 8) ──
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PUBLISHABLE_KEY=""
# Dev only: if your account doesn't have Connect enabled yet, set "true" to
# charge the platform account directly. In production: always empty/false.
STRIPE_DIRECT_CHARGES=""
