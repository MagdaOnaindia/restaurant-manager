generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Los modelos de dominio se añaden por fases (ver plan):
// Fase 5: ReservationShift, Reservation
// Fase 7+: Check, CheckLine, PaymentIntentRecord, LineClaim

// ─────────────────────────── Identidad ───────────────────────────

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  // Nullable para poder añadir SSO (Google, etc.) sin migración
  passwordHash String?
  name         String
  emailVerifiedAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tokens      VerificationToken[]
  sessions    Session[]
  memberships Membership[]

  @@map("users")
}

enum VerificationTokenType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

model VerificationToken {
  id        String                @id @default(cuid())
  userId    String
  user      User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      VerificationTokenType
  // Se guarda el hash SHA-256 del token, nunca el token en claro
  tokenHash String                @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime              @default(now())

  @@index([userId, type])
  @@map("verification_tokens")
}

// ─────────────────────── Organizaciones ──────────────────────────

enum OrgRole {
  OWNER
  ADMIN
  MANAGER
  STAFF
}

// La "cadena" o negocio; agrupa restaurantes y cuentas de empleados.
model Organization {
  id        String   @id @default(cuid())
  name      String
  // Stripe Connect (Fase 8)
  stripeAccountId      String?  @unique
  stripeChargesEnabled Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships Membership[]
  invitations Invitation[]
  restaurants Restaurant[]

  @@map("organizations")
}

model Membership {
  id             String       @id @default(cuid())
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role           OrgRole
  createdAt      DateTime     @default(now())

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@map("memberships")
}

model Invitation {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  email          String
  role           OrgRole
  tokenHash      String       @unique
  invitedByName  String
  expiresAt      DateTime
  acceptedAt     DateTime?
  createdAt      DateTime     @default(now())

  @@index([organizationId])
  @@map("invitations")
}

model Restaurant {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  // Slug único global: identifica la página pública (/r/[slug])
  slug           String       @unique
  description    String?
  address        String?
  city           String?
  phone          String?
  timezone       String       @default("Europe/Madrid")
  currency       String       @default("EUR")
  // Visibilidad de la página pública (Fase 6)
  isPublic       Boolean      @default(false)
  // Horarios de apertura por día de semana (estructura JSON, Fase 5/6)
  openingHours   Json?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  zones Zone[]
  menus Menu[]

  @@index([organizationId])
  @@map("restaurants")
}

// ─────────────────────── Cartas y menús ──────────────────────────

enum MenuType {
  A_LA_CARTE // carta normal: cada plato con su precio
  FIXED_PRICE // menú del día / degustación: precio cerrado
}

enum MenuStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

// Los 14 alérgenos de declaración obligatoria en la UE
enum Allergen {
  GLUTEN
  CRUSTACEANS
  EGGS
  FISH
  PEANUTS
  SOY
  DAIRY
  NUTS
  CELERY
  MUSTARD
  SESAME
  SULPHITES
  LUPIN
  MOLLUSCS
}

model Menu {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  name         String
  description  String?
  type         MenuType   @default(A_LA_CARTE)
  status       MenuStatus @default(DRAFT)
  // Solo para FIXED_PRICE: precio del menú completo, en céntimos
  priceCents   Int?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  categories MenuCategory[]
  schedules  MenuSchedule[]

  @@index([restaurantId])
  @@map("menus")
}

// Vigencia temporal de un menú. Un menú sin vigencias está siempre activo.
// Ejemplos: "Carta de verano" (dateFrom/dateTo), "Menú del día" (daysOfWeek 1-5 + franja horaria).
model MenuSchedule {
  id         String    @id @default(cuid())
  menuId     String
  menu       Menu      @relation(fields: [menuId], references: [id], onDelete: Cascade)
  dateFrom   DateTime? @db.Date
  dateTo     DateTime? @db.Date
  // Días ISO: 1=lunes … 7=domingo. Vacío = todos los días.
  daysOfWeek Int[]     @default([])
  // Franja horaria local del restaurante, formato "HH:MM". Null = todo el día.
  timeFrom   String?
  timeTo     String?

  @@index([menuId])
  @@map("menu_schedules")
}

model MenuCategory {
  id          String  @id @default(cuid())
  menuId      String
  menu        Menu    @relation(fields: [menuId], references: [id], onDelete: Cascade)
  name        String
  description String?
  sortOrder   Int     @default(0)
  // En menús de precio cerrado: cuántos platos elige el comensal en esta sección
  choiceCount Int?

  items MenuItem[]

  @@index([menuId])
  @@map("menu_categories")
}

model MenuItem {
  id          String     @id @default(cuid())
  categoryId  String
  category    MenuCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  name        String
  description String?
  // En carta: precio del plato. En menú cerrado suele ser 0 (va incluido).
  priceCents  Int        @default(0)
  photoUrl    String?
  allergens   Allergen[] @default([])
  // Etiquetas libres: "vegano", "picante", "sin gluten"…
  tags        String[]   @default([])
  isAvailable Boolean    @default(true)
  sortOrder   Int        @default(0)
  createdAt   DateTime   @default(now())

  modifierGroups ItemModifierGroup[]

  @@index([categoryId])
  @@map("menu_items")
}

// Opciones de un plato ("Punto de la carne", "Extras"…)
model ItemModifierGroup {
  id        String   @id @default(cuid())
  itemId    String
  item      MenuItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  name      String
  minSelect Int      @default(0)
  maxSelect Int      @default(1)
  sortOrder Int      @default(0)

  modifiers ItemModifier[]

  @@index([itemId])
  @@map("item_modifier_groups")
}

model ItemModifier {
  id         String            @id @default(cuid())
  groupId    String
  group      ItemModifierGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  name       String
  priceCents Int               @default(0)
  sortOrder  Int               @default(0)

  @@index([groupId])
  @@map("item_modifiers")
}

// ─────────────────────── Sala: zonas y mesas ─────────────────────

model Zone {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  name         String
  sortOrder    Int        @default(0)
  createdAt    DateTime   @default(now())

  tables Table[]

  @@index([restaurantId])
  @@map("zones")
}

model Table {
  id        String   @id @default(cuid())
  zoneId    String
  zone      Zone     @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  name      String
  capacity  Int      @default(2)
  // Código corto inmutable impreso en el QR físico de la mesa (PAY_URL/t/{qrCode})
  qrCode    String   @unique
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@index([zoneId])
  @@map("tables")
}

// Sesiones de refresh token (rotación + revocación en logout)
model Session {
  id               String    @id @default(cuid())
  userId           String
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshTokenHash String    @unique
  expiresAt        DateTime
  revokedAt        DateTime?
  createdAt        DateTime  @default(now())

  @@index([userId])
  @@map("sessions")
}
