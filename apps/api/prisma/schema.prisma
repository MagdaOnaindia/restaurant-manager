generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ──────────────── Table bills (Project B) ────────────────────────

enum CheckStatus {
  OPEN
  PARTIALLY_PAID
  PAID
  CLOSED
  CANCELLED
}

// A table's bill. Only one can be open per table at a time.
model Check {
  id           String      @id @default(cuid())
  restaurantId String
  restaurant   Restaurant  @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  tableId      String?
  table        Table?      @relation(fields: [tableId], references: [id], onDelete: SetNull)
  // Snapshot of the table name (survives deletes/renames)
  tableName    String
  status       CheckStatus @default(OPEN)
  // Anonymous diner access from the QR (Phase 9)
  publicToken  String      @unique
  notes        String?
  openedById   String?
  closedAt     DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  lines    CheckLine[]
  payments Payment[]
  claims   LineClaim[]

  @@index([restaurantId, status])
  @@index([tableId])
  @@map("checks")
}

// Bill line with a name and price snapshot (the menu can change).
model CheckLine {
  id             String    @id @default(cuid())
  checkId        String
  check          Check     @relation(fields: [checkId], references: [id], onDelete: Cascade)
  menuItemId     String?
  menuItem       MenuItem? @relation(fields: [menuItemId], references: [id], onDelete: SetNull)
  name           String
  unitPriceCents Int
  quantity       Int       @default(1)
  // Units already paid in the item-level split (Phase 9)
  paidUnits      Int       @default(0)
  notes          String?
  createdAt      DateTime  @default(now())

  claims LineClaim[]

  @@index([checkId])
  @@map("check_lines")
}

// ───────────────── Split-payment records ─────────────────────────

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

enum PaymentMethod {
  STRIPE
  CASH
}

// Mirror of every payment attempt (Stripe PaymentIntent or a manual cash charge).
model Payment {
  id                    String        @id @default(cuid())
  checkId               String
  check                 Check         @relation(fields: [checkId], references: [id], onDelete: Cascade)
  // Amount that covers the bill (WITHOUT tip), in cents
  amountCents           Int
  tipCents              Int           @default(0)
  status                PaymentStatus @default(PENDING)
  method                PaymentMethod @default(STRIPE)
  stripePaymentIntentId String?       @unique
  payerName             String?
  receiptEmail          String?
  // What it covers: { mode, shares?: {total,pay}, claims?: [{lineId, units}] }
  coverage              Json?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  @@index([checkId])
  @@map("payments")
}

// Temporary reservation of line units during the item-level split:
// prevents two diners from paying for the same dish at the same time.
model LineClaim {
  id        String    @id @default(cuid())
  checkId   String
  check     Check     @relation(fields: [checkId], references: [id], onDelete: Cascade)
  lineId    String
  line      CheckLine @relation(fields: [lineId], references: [id], onDelete: Cascade)
  // Anonymous diner session (cookie/localStorage)
  sessionId String
  units     Int
  // Linked to the payment when the diner starts checkout
  paymentId String?
  expiresAt DateTime
  createdAt DateTime  @default(now())

  @@index([lineId])
  @@index([checkId, sessionId])
  @@map("line_claims")
}

// ───────────────────────── Reservations ──────────────────────────

enum ReservationStatus {
  PENDING
  CONFIRMED
  SEATED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum ReservationSource {
  STAFF
  PUBLIC
}

// Bookable shift ("Lunch", "Dinner") with per-slot arrival capacity (pacing).
model ReservationShift {
  id              String     @id @default(cuid())
  restaurantId    String
  restaurant      Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  name            String
  // ISO days 1-7; empty = every day
  daysOfWeek      Int[]      @default([])
  startTime       String // "13:00" — first arrival time
  endTime         String // "15:30" — last arrival time
  slotMinutes     Int        @default(15)
  // Max diners that can ARRIVE in each slot (kitchen/floor pacing)
  maxCoversPerSlot Int       @default(20)
  isActive        Boolean    @default(true)
  createdAt       DateTime   @default(now())

  reservations Reservation[]

  @@index([restaurantId])
  @@map("reservation_shifts")
}

model Reservation {
  id            String            @id @default(cuid())
  restaurantId  String
  restaurant    Restaurant        @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  shiftId       String?
  shift         ReservationShift? @relation(fields: [shiftId], references: [id], onDelete: SetNull)
  date          DateTime          @db.Date
  time          String // "HH:MM" restaurant local time
  partySize     Int
  customerName  String
  customerPhone String?
  customerEmail String?
  notes         String?
  tableId       String?
  table         Table?            @relation(fields: [tableId], references: [id], onDelete: SetNull)
  status        ReservationStatus @default(CONFIRMED)
  source        ReservationSource
  // Token for the public cancellation link in the confirmation email
  cancelToken   String            @unique
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([restaurantId, date])
  @@map("reservations")
}

// ─────────────────────────── Identity ────────────────────────────

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  // Nullable so SSO (Google, etc.) can be added without a migration
  passwordHash String?
  name         String
  emailVerifiedAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tokens      VerificationToken[]
  sessions    Session[]
  memberships Membership[]

  @@map("users")
}

enum VerificationTokenType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

model VerificationToken {
  id        String                @id @default(cuid())
  userId    String
  user      User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      VerificationTokenType
  // Stores the SHA-256 hash of the token, never the token in clear text
  tokenHash String                @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime              @default(now())

  @@index([userId, type])
  @@map("verification_tokens")
}

// ─────────────────────── Organizations ───────────────────────────

enum OrgRole {
  OWNER
  ADMIN
  MANAGER
  STAFF
}

// The "chain" or business; groups restaurants and staff accounts.
model Organization {
  id        String   @id @default(cuid())
  name      String
  // Stripe Connect (Phase 8)
  stripeAccountId      String?  @unique
  stripeChargesEnabled Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships Membership[]
  invitations Invitation[]
  restaurants Restaurant[]

  @@map("organizations")
}

model Membership {
  id             String       @id @default(cuid())
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role           OrgRole
  createdAt      DateTime     @default(now())

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@map("memberships")
}

model Invitation {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  email          String
  role           OrgRole
  tokenHash      String       @unique
  invitedByName  String
  expiresAt      DateTime
  acceptedAt     DateTime?
  createdAt      DateTime     @default(now())

  @@index([organizationId])
  @@map("invitations")
}

model Restaurant {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  // Globally unique slug: identifies the public page (/r/[slug])
  slug           String       @unique
  description    String?
  address        String?
  city           String?
  phone          String?
  timezone       String       @default("Europe/Madrid")
  currency       String       @default("EUR")
  // Public page visibility (Phase 6)
  isPublic       Boolean      @default(false)
  // Opening hours by day of week (JSON structure, Phase 5/6)
  openingHours   Json?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  zones             Zone[]
  menus             Menu[]
  reservationShifts ReservationShift[]
  reservations      Reservation[]
  checks            Check[]

  @@index([organizationId])
  @@map("restaurants")
}

// ─────────────────────── Menus ───────────────────────────────────

enum MenuType {
  A_LA_CARTE // regular menu: each dish has its own price
  FIXED_PRICE // daily/tasting menu: fixed price
}

enum MenuStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

// The 14 allergens whose declaration is mandatory in the EU
enum Allergen {
  GLUTEN
  CRUSTACEANS
  EGGS
  FISH
  PEANUTS
  SOY
  DAIRY
  NUTS
  CELERY
  MUSTARD
  SESAME
  SULPHITES
  LUPIN
  MOLLUSCS
}

model Menu {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  name         String
  description  String?
  type         MenuType   @default(A_LA_CARTE)
  status       MenuStatus @default(DRAFT)
  // FIXED_PRICE only: price of the whole menu, in cents
  priceCents   Int?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  categories MenuCategory[]
  schedules  MenuSchedule[]

  @@index([restaurantId])
  @@map("menus")
}

// Time-based validity of a menu. A menu with no schedules is always active.
// Examples: "Summer menu" (dateFrom/dateTo), "Daily menu" (daysOfWeek 1-5 + time slot).
model MenuSchedule {
  id         String    @id @default(cuid())
  menuId     String
  menu       Menu      @relation(fields: [menuId], references: [id], onDelete: Cascade)
  dateFrom   DateTime? @db.Date
  dateTo     DateTime? @db.Date
  // ISO days: 1=Monday … 7=Sunday. Empty = every day.
  daysOfWeek Int[]     @default([])
  // Restaurant local time slot, "HH:MM" format. Null = all day.
  timeFrom   String?
  timeTo     String?

  @@index([menuId])
  @@map("menu_schedules")
}

model MenuCategory {
  id          String  @id @default(cuid())
  menuId      String
  menu        Menu    @relation(fields: [menuId], references: [id], onDelete: Cascade)
  name        String
  description String?
  sortOrder   Int     @default(0)
  // Fixed-price menus: how many dishes the diner picks in this section
  choiceCount Int?

  items MenuItem[]

  @@index([menuId])
  @@map("menu_categories")
}

model MenuItem {
  id          String     @id @default(cuid())
  categoryId  String
  category    MenuCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  name        String
  description String?
  // À la carte: dish price. In a fixed-price menu it's usually 0 (included).
  priceCents  Int        @default(0)
  photoUrl    String?
  allergens   Allergen[] @default([])
  // Free-form tags: "vegan", "spicy", "gluten-free"…
  tags        String[]   @default([])
  isAvailable Boolean    @default(true)
  sortOrder   Int        @default(0)
  createdAt   DateTime   @default(now())

  modifierGroups ItemModifierGroup[]
  checkLines     CheckLine[]

  @@index([categoryId])
  @@map("menu_items")
}

// Options for a dish ("Steak doneness", "Extras"…)
model ItemModifierGroup {
  id        String   @id @default(cuid())
  itemId    String
  item      MenuItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  name      String
  minSelect Int      @default(0)
  maxSelect Int      @default(1)
  sortOrder Int      @default(0)

  modifiers ItemModifier[]

  @@index([itemId])
  @@map("item_modifier_groups")
}

model ItemModifier {
  id         String            @id @default(cuid())
  groupId    String
  group      ItemModifierGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  name       String
  priceCents Int               @default(0)
  sortOrder  Int               @default(0)

  @@index([groupId])
  @@map("item_modifiers")
}

// ─────────────────────── Floor: zones and tables ─────────────────

model Zone {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  name         String
  sortOrder    Int        @default(0)
  createdAt    DateTime   @default(now())

  tables Table[]

  @@index([restaurantId])
  @@map("zones")
}

model Table {
  id        String   @id @default(cuid())
  zoneId    String
  zone      Zone     @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  name      String
  capacity  Int      @default(2)
  // Immutable short code printed on the table's physical QR (PAY_URL/t/{qrCode})
  qrCode    String   @unique
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  reservations Reservation[]
  checks       Check[]

  @@index([zoneId])
  @@map("tables")
}

// Refresh-token sessions (rotation + revocation on logout)
model Session {
  id               String    @id @default(cuid())
  userId           String
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshTokenHash String    @unique
  expiresAt        DateTime
  revokedAt        DateTime?
  createdAt        DateTime  @default(now())

  @@index([userId])
  @@map("sessions")
}
