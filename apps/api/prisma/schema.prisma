generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Los modelos de dominio se añaden por fases (ver plan):
// Fase 3: Zone, Table
// Fase 4: Menu, MenuSchedule, MenuCategory, MenuItem, ItemModifierGroup, ItemModifier
// Fase 5: ReservationShift, Reservation
// Fase 7+: Check, CheckLine, PaymentIntentRecord, LineClaim

// ─────────────────────────── Identidad ───────────────────────────

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  // Nullable para poder añadir SSO (Google, etc.) sin migración
  passwordHash String?
  name         String
  emailVerifiedAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tokens      VerificationToken[]
  sessions    Session[]
  memberships Membership[]

  @@map("users")
}

enum VerificationTokenType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

model VerificationToken {
  id        String                @id @default(cuid())
  userId    String
  user      User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      VerificationTokenType
  // Se guarda el hash SHA-256 del token, nunca el token en claro
  tokenHash String                @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime              @default(now())

  @@index([userId, type])
  @@map("verification_tokens")
}

// ─────────────────────── Organizaciones ──────────────────────────

enum OrgRole {
  OWNER
  ADMIN
  MANAGER
  STAFF
}

// La "cadena" o negocio; agrupa restaurantes y cuentas de empleados.
model Organization {
  id        String   @id @default(cuid())
  name      String
  // Stripe Connect (Fase 8)
  stripeAccountId      String?  @unique
  stripeChargesEnabled Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships Membership[]
  invitations Invitation[]
  restaurants Restaurant[]

  @@map("organizations")
}

model Membership {
  id             String       @id @default(cuid())
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role           OrgRole
  createdAt      DateTime     @default(now())

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@map("memberships")
}

model Invitation {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  email          String
  role           OrgRole
  tokenHash      String       @unique
  invitedByName  String
  expiresAt      DateTime
  acceptedAt     DateTime?
  createdAt      DateTime     @default(now())

  @@index([organizationId])
  @@map("invitations")
}

model Restaurant {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  // Slug único global: identifica la página pública (/r/[slug])
  slug           String       @unique
  description    String?
  address        String?
  city           String?
  phone          String?
  timezone       String       @default("Europe/Madrid")
  currency       String       @default("EUR")
  // Visibilidad de la página pública (Fase 6)
  isPublic       Boolean      @default(false)
  // Horarios de apertura por día de semana (estructura JSON, Fase 5/6)
  openingHours   Json?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
  @@map("restaurants")
}

// Sesiones de refresh token (rotación + revocación en logout)
model Session {
  id               String    @id @default(cuid())
  userId           String
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshTokenHash String    @unique
  expiresAt        DateTime
  revokedAt        DateTime?
  createdAt        DateTime  @default(now())

  @@index([userId])
  @@map("sessions")
}
